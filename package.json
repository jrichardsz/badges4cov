{
  "name": "badges4cov",
  "version": "1.0.2",
  "type": "module",
  "description": "Yes, another image badges generator for nyc coverage json report",
  "main": "src/main/ShellExecutor.js",
  "bin": {
    "badges4cov": "src/main/ShellExecutor.js"
  },
  "scripts": {
    "test": "c8 --reporter=html --reporter=json-summary mocha 'src/test/**/*.test.js' --exit --require mocha-suppress-logs",
    "test:verbose": "c8 --reporter=html --reporter=json-summary mocha 'src/test/**/*.test.js' --exit",
    "badges": "node ./src/main/ShellExecutor.js --source=nyc_json --nyc_json_file_location=./coverage/coverage-summary.json --output_folder=coverage"
  },
  "author": "jrichardsz <jrichardsz.java@gmail.com>",
  "license": "MIT",
  "devDependencies": {
    "chai": "6.2.2",
    "mocha": "^11.3.0",
    "mocha-suppress-logs": "^0.6.0"
  },
  "dependencies": {
    "args-parser": "^1.3.0",
    "badgs": "^1.1.1",
    "jsonpath": "^1.3.0"
  },
  "overrides": {
    "mocha": {
      "serialize-javascript": "^7.0.1"
    },
    "jsonpath": {
      "underscore": "^1.13.7" 
    }
  }
}
